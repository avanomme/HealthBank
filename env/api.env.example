# HealthBank API Environment Configuration
# Copy this file to api.dev.env, api.prod.env, or api.local.env and fill in your values
# NEVER commit files containing actual credentials!

# ===============================
# Database Configuration
# ===============================
DATABASE_URL=mysql://username:password@mysql:3306/healthdatabase

# ===============================
# Cookie Security
# ===============================
# Set to true in production with HTTPS. false for local HTTP dev.
COOKIE_SECURE=false

# ===============================
# CORS Configuration
# ===============================
# Development: * (or http://localhost:3000,http://localhost:8000)
# Production: https://yourdomain.com (explicit, never wildcard)
CORS_ORIGINS=*

# ===============================
# Email / SMTP Configuration
# ===============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=HealthBank
SMTP_TIMEOUT=30

# ===============================
# Application URLs
# ===============================
APP_BASE_URL=http://localhost:8000

# ===============================
# 2FA Master Key
# ===============================
# Generate a strong random string (e.g., openssl rand -base64 32)
2FA_MASTER_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_STRING

# ===============================
# Terms of Service Version
# ===============================
CURRENT_TOS_VERSION=2026-01-31

# ===============================
# MFA Settings
# ===============================
MFA_CHALLENGE_TTL_MINUTES=10
MFA_MAX_ATTEMPTS=5
