# HealthBank Environment Variables
# ================================
# Copy this file and update values for your environment.
# Development configs are in env/ folder (shared in repo).
# Production secrets should be in a separate, gitignored location.

# ===============================
# DATABASE (MySQL)
# ===============================
# Used by: API container, MySQL container
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE

DATABASE_URL=mysql://myuser:mypassword@mysql:3306/healthdatabase

# MySQL container initialization
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=healthdatabase
MYSQL_USER=myuser
MYSQL_PASSWORD=your_password_here

# ===============================
# EMAIL / SMTP (Gmail)
# ===============================
# Used by: API container (backend/app/services/email/)
#
# To generate Gmail App Password:
# 1. Enable 2FA on Google Account
# 2. Go to: Google Account > Security > App Passwords
# 3. Generate new app password for "Mail"
# 4. Use the 16-character password (no spaces)

GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ===============================
# APPLICATION URLs
# ===============================
# Used by: Email templates (password reset links, etc.)

APP_BASE_URL=http://localhost:3000

# ===============================
# ENVIRONMENT FILES STRUCTURE
# ===============================
# env/
# ├── api.dev.env      # API dev config (DATABASE_URL, EMAIL, APP_BASE_URL)
# ├── api.prod.env     # API prod config
# ├── mysql.dev.env    # MySQL dev config (MYSQL_ROOT_PASSWORD, etc.)
# ├── mysql.prod.env   # MySQL prod config
# ├── frontend.dev.env # Frontend dev config (if needed)
# └── frontend.prod.env# Frontend prod config (if needed)

# ===============================
# DOCKER COMPOSE USAGE
# ===============================
# Development:  docker compose --env-file env/api.dev.env up -d
# Production:   docker compose up -d (uses env/*.prod.env by default)

# ===============================
# REQUIRED FOR EACH ENVIRONMENT
# ===============================
#
# api.prod.env (or api.dev.env):
#   - DATABASE_URL
#   - GMAIL_USER
#   - GMAIL_APP_PASSWORD
#   - APP_BASE_URL
#
# mysql.prod.env (or mysql.dev.env):
#   - MYSQL_ROOT_PASSWORD
#   - MYSQL_DATABASE
#   - MYSQL_USER
#   - MYSQL_PASSWORD
